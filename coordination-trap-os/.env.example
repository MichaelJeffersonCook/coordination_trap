# Copy to .env to override defaults. The prototype runs with zero config.

# LLM provider for agent narration: mock | anthropic | openai
CTOS_LLM_PROVIDER=mock

# Required only if provider is "anthropic"
# ANTHROPIC_API_KEY=sk-ant-...
# CTOS_ANTHROPIC_MODEL=claude-opus-4-8

# Required only if provider is "openai"
# OPENAI_API_KEY=sk-...
# CTOS_OPENAI_MODEL=gpt-4o

# Pin the prototype's "today" for deterministic demos (The Curve 2027 scenario)
CTOS_DEMO_TODAY=2027-04-21

# Override the SQLite path if you like
# CTOS_DB_PATH=./workgraph.db
